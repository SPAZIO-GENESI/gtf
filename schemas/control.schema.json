{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "control.schema.json",
  "title": "Controllo (CTL)",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^CTL-[\\w-]+$" },
    "title": { "type": "string" },
    "statement": { "type": "string", "description": "Testo pubblico verbatim del controllo, quando il controllo È una dichiarazione (es. posizionamento eIDAS) e non solo un meccanismo tecnico" },
    "status": { "type": "string", "enum": ["draft", "active", "stale", "retired"], "default": "draft" },
    "visibility": { "type": "string", "enum": ["public", "internal", "secret"], "default": "public" },
    "why_not_public": { "type": "string" },
    "satisfies": { "type": "array", "items": { "type": "string" } },
    "mitigates": { "type": "array", "items": { "type": "string" } },
    "implemented_by": { "type": "array", "items": { "type": "string" } },
    "evidenced_by": { "type": "array", "items": { "type": "string" } },
    "verify_howto": { "type": "string" },
    "owner": { "type": "string" },
    "review_every_days": { "type": "integer", "minimum": 1 },
    "last_reviewed": { "type": "string", "format": "date" }
  },
  "required": ["id", "title", "status"],
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "active" } } },
      "then": { "required": ["implemented_by", "evidenced_by"] }
    },
    {
      "if": { "properties": { "visibility": { "enum": ["internal", "secret"] } }, "required": ["visibility"] },
      "then": { "required": ["why_not_public"] }
    }
  ],
  "additionalProperties": false
}
